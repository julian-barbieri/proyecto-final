# ==========================================
# ENTORNOS VIRTUALES Y DEPENDENCIAS
# ==========================================

venv/
.venv/
env/
.env
.env.local
*.egg-info/

# ==========================================
# ARCHIVOS COMPILADOS Y CACHÉ
# ==========================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg

# ==========================================
# MODELOS Y DATOS (CRÍTICO EN DATA SCIENCE)
# ==========================================

# Modelos entrenados grandes (los .pkl del proyecto se incluyen explícitamente)
src/models/models-trained/*.joblib
src/models/models-trained/*.h5
src/models/models-trained/*.pt
src/models/models-trained/*.pth
# Forzar inclusión de los .pkl del proyecto (override del *.pkl global)
!src/models/models-trained/modelo_alumno.pkl
!src/models/models-trained/modelo_materia.pkl
!src/models/models-trained/modelo_examen.pkl
src/models/training/

# Datasets de prueba/entrenamiento
src/dataset-test/
src/dataset-test/*.csv
src/dataset-test/*.xlsx
src/dataset-test/*.parquet

# Datasets locales
data/*.csv
data/*.xlsx
data/*.parquet
data/*.json

# Outputs y análisis
outputs/
outputs/shap/
outputs/shap/*.csv

# ==========================================
# JUPYTER Y NOTEBOOKS
# ==========================================

.ipynb_checkpoints/
*/.ipynb_checkpoints/
*.ipynb_checkpoints

