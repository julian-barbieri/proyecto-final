# =============================================================================
# .env - Variables de entorno para desarrollo
# 
# Copiar a .env.local para desarrollo local
# En Docker, usar variables en docker-compose.yml
# =============================================================================

# ===== FastAPI (ai-service) =====
# Puerto de escucha
FASTAPI_PORT=8000

# Modo debug
FASTAPI_DEBUG=false

# Logging
LOG_LEVEL=INFO

# ===== Streamlit =====
STREAMLIT_PORT=8501
AI_SERVICE_URL=http://localhost:8000

# En Docker, usar:
# AI_SERVICE_URL=http://ai-service:8000

# ===== Modelos ML =====
# Rutas a modelos (relativas a ai-service/)
MODELS_DIR=src/models/models-trained

# ===== Base de datos (si se conecta a backend) =====
# DATABASE_URL=http://localhost:3000

# ===== Variables de producción (comentadas) =====
# URL_API_BACKEND=https://api.proyecto.com
# ORIGIN_FRONTEND=https://app.proyecto.com
